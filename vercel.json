{
  "crons": [
    {
      "path": "/api/cron/track-signals",
      "schedule": "30 18 * * 1-5"
    },
    {
      "path": "/api/cron/morning-digest",
      "schedule": "30 5 * * 1-5"
    },
    {
      "path": "/api/cron/track-verdicts",
      "schedule": "45 18 * * 1-5"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 19 * * 5"
    },
    {
      "path": "/api/cron/score-change-alerts",
      "schedule": "0 19 * * 1-5"
    },
    {
      "path": "/api/cron/macro-alerts",
      "schedule": "0 17 * * 1-5"
    },
    {
      "path": "/api/cron/intraday-scan",
      "schedule": "*/15 7-15 * * 1-5"
    },
    {
      "path": "/api/cron/intraday-scan?partition=1",
      "schedule": "0 7,12 * * 1-5"
    },
    {
      "path": "/api/cron/intraday-scan?partition=2",
      "schedule": "2 7,12 * * 1-5"
    },
    {
      "path": "/api/cron/intraday-scan?partition=3",
      "schedule": "4 7,12 * * 1-5"
    },
    {
      "path": "/api/cron/intraday-scan?partition=4",
      "schedule": "6 7,12 * * 1-5"
    }
  ]
