generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---- NextAuth Models ----

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Application Models ----

enum Plan {
  FREE
  PREMIUM
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String      @unique
  emailVerified DateTime?
  image         String?
  plan          Plan        @default(FREE)
  role          Role        @default(USER)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  portfolios    Portfolio[]
  accounts      Account[]
  sessions      Session[]
  alertPrefs    AlertPreference?
  aiDisclaimerAccepted Boolean @default(false)
}

model AlertPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  morningDigest     Boolean  @default(true)   // Sabah 08:30 portföy özeti
  signalAlerts      Boolean  @default(true)   // Yeni sinyal bildirimi
  scoreChangeAlerts Boolean  @default(true)   // Skor ±15 puan değişim
  macroAlerts       Boolean  @default(true)   // USD/TRY %2+, VIX 25+
  weeklyReport      Boolean  @default(true)   // Cuma haftalık rapor
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Portfolio {
  id        String   @id @default(cuid())
  userId    String
  stockCode String   // e.g. THYAO
  quantity  Float?   // lot sayısı (opsiyonel)
  avgCost   Float?   // ortalama maliyet TL (opsiyonel)
  addedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stockCode])
  @@index([userId])
}

model DailySummary {
  id              String   @id @default(cuid())
  stockCode       String
  date            DateTime @db.Date
  closePrice      Float?
  changePercent   Float?
  volume          BigInt?
  newsHeadlines   Json?
  aiSummaryText   String?  @db.Text
  sentimentScore  String?  // legacy: POSITIVE, NEGATIVE, NEUTRAL
  status          String   @default("PENDING")
  timeframe       String   @default("daily") // daily, weekly, monthly
  // v2 fields
  compositeScore  Float?   // 0-100
  sentimentValue  Float?   // -100 to +100
  bullCase        String?  @db.Text
  bearCase        String?  @db.Text
  confidence      String?  // HIGH, MEDIUM, LOW
  sectorCode      String?
  sectorChange    Float?
  relativeStrength Float?  // stock change - sector change
  bist100Change   Float?
  verdictReason   String?  @db.Text
  analyzedAt      DateTime?  // Analiz yapılma saati (cron zamanı)
  // v3: Verdict tracking
  verdictAction     String?   // GUCLU_AL, AL, TUT, SAT, GUCLU_SAT
  verdictScore      Float?    // -1.0 to +1.0
  verdictConfidence Float?    // 5-95
  // v3: Outcome tracking
  priceAfter1D      Float?
  priceAfter5D      Float?
  priceAfter10D     Float?
  priceAfter20D     Float?
  outcomePercent1D  Float?
  outcomePercent5D  Float?
  outcomePercent10D Float?
  outcomePercent20D Float?
  verdictAccurate   Boolean?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([stockCode, date, timeframe])
  @@index([stockCode, date])
  @@index([status])
  @@index([verdictAction])
}

// ---- v2: Technical Indicators (persisted, not ephemeral) ----

model TechnicalSnapshot {
  id            String   @id @default(cuid())
  stockCode     String
  date          DateTime @db.Date
  closePrice    Float?
  // RSI
  rsi14         Float?
  // Moving Averages
  ma20          Float?
  ma50          Float?
  ma200         Float?
  ema12         Float?
  ema26         Float?
  // MACD
  macdLine      Float?
  macdSignal    Float?
  macdHistogram Float?
  // Bollinger Bands
  bbUpper       Float?
  bbMiddle      Float?
  bbLower       Float?
  bbWidth       Float?
  bbPercentB    Float?
  // ATR
  atr14         Float?
  // Stochastic
  stochK        Float?
  stochD        Float?
  // OBV
  obv           Float?
  obvMa20       Float?
  // ADX
  adx14         Float?
  plusDI         Float?
  minusDI       Float?
  // Volume
  volume        BigInt?
  volumeAvg20   Float?
  volumeRatio   Float?
  // Support / Resistance
  supportLevel  Float?
  resistLevel   Float?
  // Composite Scores
  technicalScore  Float?
  momentumScore   Float?
  volumeScore     Float?
  volatilityScore Float?
  compositeScore  Float?
  createdAt     DateTime @default(now())

  @@unique([stockCode, date])
  @@index([stockCode])
  @@index([date])
}

model Signal {
  id              String   @id @default(cuid())
  stockCode       String
  date            DateTime @db.Date
  signalType      String   // GOLDEN_CROSS, RSI_OVERSOLD, MACD_BULLISH_CROSS, etc.
  signalDirection String   // BULLISH, BEARISH, NEUTRAL
  strength        Float    // 0-100
  description     String   @db.Text
  // Outcome tracking
  priceAtSignal     Float?
  priceAfter1Day    Float?
  priceAfter5Days   Float?
  priceAfter10Days  Float?
  outcomePercent1D  Float?
  outcomePercent5D  Float?
  outcomePercent10D Float?
  wasAccurate       Boolean?
  confirmed         Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@unique([stockCode, date, signalType, signalDirection])
  @@index([stockCode])
  @@index([date])
  @@index([signalType])
  @@index([stockCode, date])
  @@index([strength])
  @@index([wasAccurate, date])
}

model SectorSnapshot {
  id            String   @id @default(cuid())
  sectorCode    String
  sectorName    String
  date          DateTime @db.Date
  price         Float?
  changePercent Float?
  createdAt     DateTime @default(now())

  @@unique([sectorCode, date])
  @@index([date])
}

// ---- v3: Specialized AI Insights (cached per feature per day) ----

model AiInsight {
  id          String   @id @default(cuid())
  stockCode   String
  date        DateTime @db.Date
  insightType String   // "akilli-ozet", "giris-cikis", "teknik-yorum", "sinyal-cozum", "risk-senaryo", "sektor-analiz", "islem-kurulumu"
  timeframe   String   @default("daily")
  resultJson    Json
  status        String   @default("COMPLETED")
  promptVersion String?
  aiProvider    String?
  createdAt     DateTime @default(now())

  @@unique([stockCode, date, insightType, timeframe])
  @@index([stockCode, insightType])
}

model PortfolioSnapshot {
  id                    String   @id @default(cuid())
  userId                String
  date                  DateTime @db.Date
  timeframe             String   @default("daily")

  // Verdict
  verdictAction         String?
  verdictScore          Float?
  verdictConfidence     Float?
  compositeScore        Float?

  // Metrics
  totalValue            Float?
  totalPnL              Float?
  totalPnLPercent       Float?
  dailyChange           Float?
  portfolioBeta         Float?

  // Risk
  portfolioVaR95        Float?
  diversificationScore  Float?
  avgVolatility         Float?

  // Benchmark
  bist100Return         Float?
  alpha                 Float?
  trackingError         Float?

  // JSON
  allocation            Json?
  sectorAllocation      Json?
  holdingVerdicts       Json?
  riskContributions     Json?

  createdAt             DateTime @default(now())

  @@unique([userId, date, timeframe])
  @@index([userId, timeframe])
  @@index([date])
}

// ---- v4: Screener Snapshots (cron-generated, per stock per day) ----

model ScreenerSnapshot {
  id            String   @id @default(cuid())
  stockCode     String
  date          DateTime @db.Date
  name          String?

  // Fiyat
  price         Float?
  changePercent Float?
  volume        Float?

  // Composite + Verdict
  compositeScore    Float?
  compositeJson     Json?
  verdictAction     String?
  verdictScore      Float?
  verdictConfidence Int?
  verdictJson       Json?

  // Teknik özet
  rsi14           Float?
  macdHistogram   Float?
  maAlignment     String?
  adx14           Float?

  // Temel özet
  fundamentalScore  Float?
  fundamentalJson   Json?
  peRatio           Float?
  pbRatio           Float?
  dividendYield     Float?
  fiftyTwoWeekHigh  Float?
  fiftyTwoWeekLow   Float?
  fromFiftyTwoHigh  Float?

  // Risk
  riskLevel       String?
  sharpeRatio     Float?
  maxDrawdown     Float?
  riskJson        Json?

  // Sinyaller
  signalsJson           Json?
  signalCombinationJson Json?
  bullishSignalCount    Int    @default(0)
  bearishSignalCount    Int    @default(0)

  // Multi-timeframe
  mtfAlignment    String?
  mtfJson         Json?

  // Sektör
  sectorCode      String?
  sectorName      String?

  // Endeks üyelikleri
  inBist30        Boolean @default(false)
  inBist50        Boolean @default(false)
  inBist100       Boolean @default(false)
  inXtm25         Boolean @default(false)
  inXkury         Boolean @default(false)
  inXusrd         Boolean @default(false)

  createdAt       DateTime @default(now())

  @@unique([stockCode, date])
  @@index([date])
  @@index([compositeScore])
  @@index([verdictAction])
  @@index([inBist30, date])
  @@index([inBist50, date])
  @@index([inBist100, date])
  @@index([inXtm25, date])
  @@index([inXkury, date])
  @@index([inXusrd, date])
}

// ---- v5: Admin Models ----

model CronLog {
  id        String    @id @default(cuid())
  cronName  String
  status    String    // RUNNING, SUCCESS, FAILED
  duration  Int?      // milliseconds
  result    Json?
  error     String?   @db.Text
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  @@index([cronName, startedAt])
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
